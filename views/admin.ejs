<%# ── Admin Alert Settings Card ─────────────────────────────────────────────── %>
<div class="alert-settings-card mb-4">
  <div class="card shadow-sm border-0" style="background:linear-gradient(135deg,#1a1f2e 0%,#161b22 100%);border:1px solid #30363d !important;">
    <div class="card-body p-4">
      <div class="d-flex align-items-center gap-3 mb-3">
        <div style="width:40px;height:40px;background:linear-gradient(135deg,#58a6ff,#1f6feb);border-radius:10px;display:flex;align-items:center;justify-content:center;">
          <i class="bi bi-bell-fill text-white"></i>
        </div>
        <div>
          <h5 class="mb-0 text-white fw-bold">Admin Alert Notifications</h5>
          <small class="text-secondary">You will receive alerts for <strong class="text-info">all containers</strong></small>
        </div>
      </div>
      <form action="/admin/settings/alert-email" method="POST" class="d-flex gap-2 align-items-end">
        <div class="flex-grow-1">
          <label class="form-label text-secondary small fw-semibold mb-1">Alert Email Address</label>
          <div class="input-group">
            <span class="input-group-text" style="background:#0d1117;border-color:#30363d;color:#58a6ff;"><i class="bi bi-envelope-at"></i></span>
            <input type="email" name="alert_email" id="adminAlertEmail"
                   value="<%= adminAlertEmail %>"
                   placeholder="admin@example.com"
                   class="form-control"
                   style="background:#0d1117;border-color:#30363d;color:#e6edf3;">
          </div>
          <div class="form-text text-secondary" style="font-size:11px;">Leave empty to disable admin alerts.</div>
        </div>
        <button type="submit" class="btn btn-primary px-4" style="background:linear-gradient(135deg,#1f6feb,#58a6ff);border:none;">
          <i class="bi bi-save me-1"></i>Save
        </button>
      </form>
    </div>
  </div>
</div>

<%# ── Page Header ─────────────────────────────────────────────────────────────── %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><i class="bi bi-shield-lock me-2"></i>Administration</h1>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
    <i class="bi bi-person-plus me-1"></i>Create User
  </button>
</div>

<%# ── Users Table ─────────────────────────────────────────────────────────────── %>
<div class="card shadow-sm">
  <div class="card-body p-0">
    <table class="table table-dark table-hover mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Alert Email</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td>
              <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-secondary' %>">
                <%= u.role %>
              </span>
            </td>
            <td>
              <span class="badge <%= u.status === 'active' ? 'bg-success' : 'bg-warning' %>">
                <%= u.status %>
              </span>
            </td>
            <td>
              <% if (u.alert_email) { %>
                <span class="badge bg-info text-dark" style="font-size:10px;max-width:160px;overflow:hidden;text-overflow:ellipsis;display:inline-block;vertical-align:middle;" title="<%= u.alert_email %>">
                  <i class="bi bi-bell-fill me-1"></i><%= u.alert_email %>
                </span>
              <% } else { %>
                <span class="text-secondary" style="font-size:12px;"><i class="bi bi-bell-slash me-1"></i>Not set</span>
              <% } %>
            </td>
            <td class="text-end">
              <div class="btn-group btn-group-sm">
                <a href="/admin/users/<%= u.id %>/assign" class="btn btn-outline-info" title="Assign Containers">
                  <i class="bi bi-box-arrow-in-right"></i>
                </a>
                <button class="btn btn-outline-warning" title="Edit User" 
                        data-bs-toggle="modal" data-bs-target="#editUserModal<%= u.id %>">
                  <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-outline-light" title="Reset Password"
                        data-bs-toggle="modal" data-bs-target="#resetPasswordModal<%= u.id %>">
                  <i class="bi bi-key"></i>
                </button>
                <button class="btn btn-outline-info" title="Set Alert Email"
                        data-bs-toggle="modal" data-bs-target="#alertEmailModal<%= u.id %>">
                  <i class="bi bi-bell"></i>
                </button>
                <% if (user.id !== u.id) { %>
                <form action="/admin/users/<%= u.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?')">
                  <button type="submit" class="btn btn-outline-danger" title="Delete User">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
                <% } %>
              </div>

              <%# Edit User Modal %>
              <div class="modal fade" id="editUserModal<%= u.id %>" tabindex="-1">
                <div class="modal-dialog">
                  <div class="modal-content bg-dark border-secondary text-white text-start">
                    <div class="modal-header">
                      <h5 class="modal-title">Edit User: <%= u.name %></h5>
                      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="/admin/users/<%= u.id %>/update" method="POST">
                      <div class="modal-body">
                        <div class="mb-3">
                          <label class="form-label">Full Name</label>
                          <input type="text" name="name" value="<%= u.name %>" class="form-control bg-secondary text-white border-0" required>
                        </div>
                        <div class="mb-3">
                          <label class="form-label">Email Address</label>
                          <input type="email" name="email" value="<%= u.email %>" class="form-control bg-secondary text-white border-0" required>
                        </div>
                        <div class="mb-3">
                          <label class="form-label">Role</label>
                          <select name="role" class="form-select bg-secondary text-white border-0">
                            <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                            <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                          </select>
                        </div>
                        <div class="mb-3">
                          <label class="form-label">Status</label>
                          <select name="status" class="form-select bg-secondary text-white border-0">
                            <option value="active" <%= u.status === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="inactive" <%= u.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                          </select>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning">Update User</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>

              <%# Reset Password Modal %>
              <div class="modal fade" id="resetPasswordModal<%= u.id %>" tabindex="-1">
                <div class="modal-dialog">
                  <div class="modal-content bg-dark border-secondary text-white text-start">
                    <div class="modal-header">
                      <h5 class="modal-title">Reset Password: <%= u.name %></h5>
                      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="/admin/users/<%= u.id %>/reset-password" method="POST">
                      <div class="modal-body">
                        <div class="mb-3">
                          <label class="form-label">New Password</label>
                          <input type="password" name="newPassword" class="form-control bg-secondary text-white border-0" required minlength="6">
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-light">Reset Password</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>

              <%# Alert Email Modal — Admin sets a user's alert email %>
              <div class="modal fade" id="alertEmailModal<%= u.id %>" tabindex="-1">
                <div class="modal-dialog">
                  <div class="modal-content text-white text-start" style="background:#161b22;border:1px solid #30363d;">
                    <div class="modal-header" style="border-color:#30363d;">
                      <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-bell-fill text-info"></i>
                        <h5 class="modal-title mb-0">Alert Email — <%= u.name %></h5>
                      </div>
                      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="/admin/users/<%= u.id %>/alert-email" method="POST">
                      <div class="modal-body">
                        <p class="text-secondary small mb-3">
                          <i class="bi bi-info-circle me-1"></i>
                          This user will receive email alerts for containers assigned to them.
                        </p>
                        <div class="mb-3">
                          <label class="form-label fw-semibold">Alert Email Address</label>
                          <div class="input-group">
                            <span class="input-group-text" style="background:#0d1117;border-color:#30363d;color:#58a6ff;"><i class="bi bi-envelope-at"></i></span>
                            <input type="email" name="alert_email"
                                   value="<%= u.alert_email || '' %>"
                                   placeholder="user@example.com"
                                   class="form-control"
                                   style="background:#0d1117;border-color:#30363d;color:#e6edf3;">
                          </div>
                          <div class="form-text text-secondary" style="font-size:11px;">Leave empty to disable alerts for this user.</div>
                        </div>
                      </div>
                      <div class="modal-footer" style="border-color:#30363d;">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-info"><i class="bi bi-save me-1"></i>Save Alert Email</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>

            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%# ── Create User Modal ───────────────────────────────────────────────────────── %>
<div class="modal fade" id="createUserModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content bg-dark border-secondary text-white">
      <div class="modal-header">
        <h5 class="modal-title">Create New User</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/users/create" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" name="name" class="form-control bg-secondary text-white border-0" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" name="email" class="form-control bg-secondary text-white border-0" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control bg-secondary text-white border-0" required minlength="6">
          </div>
          <div class="mb-3">
            <label class="form-label">Role</label>
            <select name="role" class="form-select bg-secondary text-white border-0">
              <option value="user">User</option>
              <option value="admin">Admin</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create User</button>
        </div>
      </form>
    </div>
  </div>
</div>

