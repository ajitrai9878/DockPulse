<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><i class="bi bi-gear me-2"></i>Management</h1>
  <div class="d-flex gap-2">
    <button class="btn btn-outline-info d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#managerAlertModal" title="Global Notification Settings">
      <i class="bi bi-bell-fill"></i>
      <span class="d-none d-md-inline">Notifications</span>
    </button>
    <button class="btn btn-primary d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#createUserModal">
      <i class="bi bi-person-plus-fill"></i>
      <span>Create User</span>
    </button>
  </div>
</div>

<%# ── Users Table ─────────────────────────────────────────────────────────────── %>
<div class="card shadow-sm border-0" style="background:#1e293b; border:1px solid #334155 !important;">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-dark table-hover mb-0" style="--bs-table-bg: transparent;">
        <thead>
          <tr style="border-bottom: 2px solid #334155;">
            <th class="ps-4 py-3 text-secondary small text-uppercase">Name</th>
            <th class="py-3 text-secondary small text-uppercase">Email</th>
            <th class="py-3 text-secondary small text-uppercase">Role</th>
            <th class="py-3 text-secondary small text-uppercase">Status</th>
            <th class="py-3 text-secondary small text-uppercase">Alert Email</th>
            <th class="pe-4 py-3 text-end text-secondary small text-uppercase">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr class="align-middle" style="border-bottom: 1px solid #334155;">
              <td class="ps-4 fw-bold"><%= u.name %></td>
              <td><%= u.email %></td>
              <td>
                <span class="badge <%= u.role === 'admin' ? 'bg-danger-subtle text-danger border border-danger-subtle' : 'bg-secondary-subtle text-secondary border border-secondary-subtle' %> px-2 py-1">
                  <%= u.role === 'admin' ? 'Manager' : u.role %>
                </span>
              </td>
              <td>
                <span class="badge <%= u.status === 'active' ? 'bg-success-subtle text-success border border-success-subtle' : 'bg-warning-subtle text-warning border border-warning-subtle' %> px-2 py-1">
                  <%= u.status %>
                </span>
              </td>
              <td>
                <% if (u.alert_email) { %>
                  <span class="text-info small d-flex align-items-center gap-1">
                    <i class="bi bi-envelope-check"></i> <%= u.alert_email %>
                  </span>
                <% } else { %>
                  <span class="text-muted small"><i class="bi bi-bell-slash"></i> Not set</span>
                <% } %>
              </td>
              <td class="pe-4 text-end">
                <div class="btn-group btn-group-sm">
                  <a href="/admin/users/<%= u.id %>/assign" class="btn btn-outline-info" title="Assign Containers"><i class="bi bi-box-arrow-in-right"></i></a>
                  <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#editUserModal<%= u.id %>" title="Edit User"><i class="bi bi-pencil"></i></button>
                  <button class="btn btn-outline-light" data-bs-toggle="modal" data-bs-target="#resetPasswordModal<%= u.id %>" title="Reset Password"><i class="bi bi-key"></i></button>
                  <button class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#alertEmailModal<%= u.id %>" title="Set User Alerts"><i class="bi bi-bell"></i></button>
                  <% if (user.id !== u.id) { %>
                    <form action="/admin/users/<%= u.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this user and all their assignments?')">
                      <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                  <% } %>
                </div>

                <%# Edit User Modal %>
                <div class="modal fade" id="editUserModal<%= u.id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content bg-dark border-secondary text-white text-start">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit User: <%= u.name %></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/admin/users/<%= u.id %>/update" method="POST">
                        <div class="modal-body">
                          <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="name" value="<%= u.name %>" class="form-control bg-secondary text-white border-0" required>
                          </div>
                          <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" name="email" value="<%= u.email %>" class="form-control bg-secondary text-white border-0" required>
                          </div>
                          <div class="mb-3">
                            <label class="form-label">Role</label>
                            <select name="role" class="form-select bg-secondary text-white border-0">
                              <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                              <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                            </select>
                          </div>
                          <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select bg-secondary text-white border-0">
                              <option value="active" <%= u.status === 'active' ? 'selected' : '' %>>Active</option>
                              <option value="inactive" <%= u.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                            </select>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-warning">Update User</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

                <%# Reset Password Modal %>
                <div class="modal fade" id="resetPasswordModal<%= u.id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content bg-dark border-secondary text-white text-start">
                      <div class="modal-header">
                        <h5 class="modal-title">Reset Password: <%= u.name %></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/admin/users/<%= u.id %>/reset-password" method="POST">
                        <div class="modal-body">
                          <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input type="password" name="newPassword" class="form-control bg-secondary text-white border-0" required minlength="6">
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-light">Reset Password</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

                <%# User Alert Email Modal (Admin sets for user) %>
                <div class="modal fade" id="alertEmailModal<%= u.id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content text-white text-start" style="background:#161b22;border:1px solid #30363d;">
                      <div class="modal-header" style="border-color:#30363d;">
                        <h5 class="modal-title">User Alerts — <%= u.name %></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/admin/users/<%= u.id %>/alert-email" method="POST">
                        <div class="modal-body">
                          <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase">Alert Email Address</label>
                            <input type="email" name="alert_email" value="<%= u.alert_email || '' %>" class="form-control bg-dark border-secondary text-white" placeholder="user@example.com">
                          </div>
                        </div>
                        <div class="modal-footer" style="border-color:#30363d;">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-info">Save Settings</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%# ── Global Notification Settings Modal (For Manager) ────────────────────────── %>
<div class="modal fade" id="managerAlertModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content text-white" style="background:#161b22;border:1px solid #30363d;">
      <div class="modal-header" style="border-color:#30363d;">
        <div class="d-flex align-items-center gap-2">
          <div style="width:36px;height:36px;background:linear-gradient(135deg,#38bdf8,#818cf8);border-radius:8px;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-bell-fill text-white" style="font-size:14px;"></i>
          </div>
          <div>
            <h5 class="modal-title mb-0">Management Notifications</h5>
            <small class="text-secondary">Global alerts for ALL container events</small>
          </div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/profile/alert-email" method="POST">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-12 mb-4">
              <label class="form-label fw-bold small text-uppercase text-info">Email Notifications</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-info"><i class="bi bi-envelope-at"></i></span>
                <input type="email" name="alert_email" value="<%= notifications.alert_email || '' %>" placeholder="admin@example.com" class="form-control bg-dark border-secondary text-white">
              </div>
              <div class="form-text text-secondary" style="font-size:11px;">Primary email for system-wide container lifecycle events.</div>
            </div>
            
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold small text-uppercase text-secondary">Slack Webhook</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-slack"></i></span>
                <input type="url" name="slack_webhook" value="<%= notifications.slack_webhook || '' %>" placeholder="https://hooks.slack.com/..." class="form-control bg-dark border-secondary text-white">
              </div>
            </div>
            
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold small text-uppercase text-secondary">Discord Webhook</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-discord"></i></span>
                <input type="url" name="discord_webhook" value="<%= notifications.discord_webhook || '' %>" placeholder="https://discord.com/api/webhooks/..." class="form-control bg-dark border-secondary text-white">
              </div>
            </div>
            
            <div class="col-md-12 mb-0">
              <label class="form-label fw-bold small text-uppercase text-secondary">Custom JSON Webhook</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-link-45deg"></i></span>
                <input type="url" name="custom_webhook" value="<%= notifications.custom_webhook || '' %>" placeholder="https://api.yourdomain.com/webhooks" class="form-control bg-dark border-secondary text-white">
              </div>
              <div class="form-text text-secondary" style="font-size:11px;">Sends a JSON payload with event details to your custom endpoint.</div>
            </div>
          </div>
        </div>
        <div class="modal-footer" style="border-color:#30363d;">
          <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary px-4" style="background:linear-gradient(135deg,#1f6feb,#58a6ff);border:none;">
            <i class="bi bi-save me-1"></i>Save All Settings
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%# ── Create User Modal ───────────────────────────────────────────────────────── %>
<div class="modal fade" id="createUserModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content bg-dark border-secondary text-white">
      <div class="modal-header">
        <h5 class="modal-title">Create New User</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/users/create" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" name="name" class="form-control bg-secondary text-white border-0" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" name="email" class="form-control bg-secondary text-white border-0" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control bg-secondary text-white border-0" required minlength="6">
          </div>
          <div class="mb-3">
            <label class="form-label">Role</label>
            <select name="role" class="form-select bg-secondary text-white border-0">
              <option value="user">User</option>
              <option value="admin">Admin</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create User</button>
        </div>
      </form>
    </div>
  </div>
</div>
