<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <h1><i class="bi bi-grid-3x3-gap me-2"></i>Dashboard</h1>
  <div class="d-flex align-items-center gap-3">
    <div class="text-muted small">Showing assigned containers</div>
    <div class="vr mx-2 d-none d-md-block"></div>
    <div class="d-flex align-items-center gap-4 d-none d-lg-flex">
      <div class="text-center">
        <div class="small text-muted text-uppercase fw-bold" style="font-size: 10px;">Host CPU</div>
        <div class="fw-bold text-info"><%= hostMetrics.cpu.load %>% <span class="text-muted small fw-normal">(<%= hostMetrics.cpu.count %> Cores)</span></div>
      </div>
      <div class="text-center">
        <div class="small text-muted text-uppercase fw-bold" style="font-size: 10px;">Host RAM</div>
        <div class="fw-bold text-primary"><%= hostMetrics.memory.percent %>% <span class="text-muted small fw-normal">(<%= hostMetrics.memory.used %>/<%= hostMetrics.memory.total %>)</span></div>
      </div>
      <div class="text-center">
        <div class="small text-muted text-uppercase fw-bold" style="font-size: 10px;">Host Disk</div>
        <div class="fw-bold text-warning"><%= hostMetrics.disk.percent %>% <span class="text-muted small fw-normal">(<%= hostMetrics.disk.used %>/<%= hostMetrics.disk.total %>)</span></div>
      </div>
      <div class="text-center">
        <div class="small text-muted text-uppercase fw-bold" style="font-size: 10px;">Uptime</div>
        <div class="fw-bold text-success"><%= hostMetrics.uptime %></div>
      </div>
    </div>
    <div class="vr mx-2 d-none d-md-block"></div>
    <button class="btn btn-sm d-flex align-items-center gap-1"
            style="background:transparent;border:1px solid #30363d;color:#e6edf3;"
            onclick="window.location.reload()"
            title="Refresh Container List">
      <i class="bi bi-arrow-clockwise"></i>
      <span class="d-none d-md-inline">Refresh</span>
    </button>
    <%# Alert email quick-set button %>
    <button class="btn btn-sm d-flex align-items-center gap-1"
            style="background:linear-gradient(135deg,#1a1f2e,#161b22);border:1px solid #30363d;color:<%= notifications.alert_email ? '#58a6ff' : '#8b949e' %>;"
            data-bs-toggle="modal" data-bs-target="#alertEmailModal"
            title="<%= notifications.alert_email ? 'Alert email: ' + notifications.alert_email : 'Set alerts' %>">
      <i class="bi bi-<%= notifications.alert_email ? 'bell-fill' : 'bell-slash' %>"></i>
      <span class="d-none d-md-inline"><%= notifications.alert_email ? 'Alerts On' : 'Alerts Off' %></span>
    </button>
  </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
  <% containers.forEach(c => { %>
    <div class="col">
      <div class="card h-100 shadow-sm hover-shadow transition">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <h5 class="card-title fw-bold text-truncate" title="<%= c.name %>"><%= c.name %></h5>
            <span class="badge <%= c.status.includes('Up') ? 'bg-success' : 'bg-danger' %>">
              <%= c.status %>
            </span>
          </div>
          <p class="card-text text-muted small mb-3">
            <i class="bi bi-tag-fill me-1"></i><%= c.image %>
          </p>
          <div class="d-grid gap-2">
            <a href="/container/<%= c.container_id %>" class="btn btn-outline-info">
              <i class="bi bi-activity me-1"></i> Monitor Logs
            </a>
            <% if (typeof role !== 'undefined' && role === 'admin') { %>
              <div class="btn-group w-100">
                <button class="btn btn-sm btn-outline-success" onclick="containerAction('<%= c.container_id %>', 'start')" title="Start">
                  <i class="bi bi-play-fill"></i>
                </button>
                <button class="btn btn-sm btn-outline-warning" onclick="containerAction('<%= c.container_id %>', 'restart')" title="Restart">
                  <i class="bi bi-arrow-repeat"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" onclick="containerAction('<%= c.container_id %>', 'stop')" title="Stop">
                  <i class="bi bi-stop-fill"></i>
                </button>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% }) %>

  <% if (containers.length === 0) { %>
    <div class="col-12 text-center py-5">
      <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
      <p class="mt-3 text-muted">No containers assigned to you.</p>
    </div>
  <% } %>
</div>

<%# ── Alert Email Modal (User's own) ──────────────────────────────────────────── %>
<div class="modal fade" id="alertEmailModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content text-white" style="background:#161b22;border:1px solid #30363d;">
      <div class="modal-header" style="border-color:#30363d;">
        <div class="d-flex align-items-center gap-2">
          <div style="width:36px;height:36px;background:linear-gradient(135deg,#58a6ff,#1f6feb);border-radius:8px;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-bell-fill text-white" style="font-size:14px;"></i>
          </div>
          <div>
            <h5 class="modal-title mb-0">My Alert Notifications</h5>
            <small class="text-secondary">Container event emails for your assigned containers</small>
          </div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/profile/alert-email" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Alert Email Address</label>
            <div class="input-group">
              <span class="input-group-text" style="background:#0d1117;border-color:#30363d;color:#58a6ff;">
                <i class="bi bi-envelope-at"></i>
              </span>
              <input type="email" name="alert_email"
                     id="userAlertEmail"
                     value="<%= notifications.alert_email %>"
                     placeholder="you@example.com"
                     class="form-control"
                     style="background:#0d1117;border-color:#30363d;color:#e6edf3;">
            </div>
          </div>
          
          <div class="mb-3">
            <label class="form-label fw-semibold">Slack Webhook URL</label>
            <input type="url" name="slack_webhook" value="<%= notifications.slack_webhook || '' %>" placeholder="https://hooks.slack.com/..." class="form-control" style="background:#0d1117;border-color:#30363d;color:#e6edf3;">
          </div>
          
          <div class="mb-3">
            <label class="form-label fw-semibold">Discord Webhook URL</label>
            <input type="url" name="discord_webhook" value="<%= notifications.discord_webhook || '' %>" placeholder="https://discord.com/api/webhooks/..." class="form-control" style="background:#0d1117;border-color:#30363d;color:#e6edf3;">
          </div>
          
          <div class="mb-3">
            <label class="form-label fw-semibold">Custom Webhook URL</label>
            <input type="url" name="custom_webhook" value="<%= notifications.custom_webhook || '' %>" placeholder="https://your-domain.com/webhook" class="form-control" style="background:#0d1117;border-color:#30363d;color:#e6edf3;">
          </div>
          
          <div class="form-text text-secondary mb-3" style="font-size:12px;">
            Leave empty to disable alerts. You will be notified when your assigned containers stop, restart, or are deleted.
          </div>

          <div class="p-3 rounded" style="background:#0d1117;border:1px solid #21262d;">
            <p class="mb-2 text-secondary" style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;">You will receive alerts for:</p>
            <div class="d-flex flex-wrap gap-2">
              <span class="badge" style="background:#e53e3e20;color:#fc8181;border:1px solid #e53e3e40;">🔴 Container Died</span>
              <span class="badge" style="background:#dd6b2020;color:#f6ad55;border:1px solid #dd6b2040;">🟠 Container Stopped</span>
              <span class="badge" style="background:#3182ce20;color:#90cdf4;border:1px solid #3182ce40;">🔵 Container Restarted</span>
              <span class="badge" style="background:#71809620;color:#cbd5e0;border:1px solid #71809640;">🗑️ Container Deleted</span>
            </div>
          </div>
        </div>
        <div class="modal-footer" style="border-color:#30363d;">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary" style="background:linear-gradient(135deg,#1f6feb,#58a6ff);border:none;">
            <i class="bi bi-save me-1"></i>Save Alert Email
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .hover-shadow:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }
</style>

<script>
  // 1. Force reload if the page was loaded from browser back-forward cache
  window.addEventListener('pageshow', function (event) {
    if (event.persisted) {
      window.location.reload();
    }
  });

  // 2. Auto-refresh the dashboard every 30 seconds to keep container statuses up-to-date
  setInterval(() => {
    // Check if the modal is currently open. If not, refresh the page.
    const modal = document.getElementById('alertEmailModal');
    if (!modal.classList.contains('show')) {
      window.location.reload();
    }
  }, 30000);

  async function containerAction(id, action) {
    if (!confirm(`Are you sure you want to ${action} this container?`)) return;
    
    try {
      const res = await fetch(`/container/${id}/action/${action}`, { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        window.location.reload();
      } else {
        alert('Error: ' + data.error);
      }
    } catch (err) {
      alert('Failed to perform action');
    }
  }
</script>
