<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Docker Monitor</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <style>
    :root {
      --bg-dark: #0f172a;
      --card-bg: #1e293b;
      --accent: #38bdf8;
      --text-muted: #cbd5e1; /* Lightened from #94a3b8 */
    }
    body {
      background-color: var(--bg-dark);
      color: #f8fafc;
      font-family: 'Inter', sans-serif;
    }
    .navbar {
      background-color: var(--card-bg) !important;
      border-bottom: 1px solid #334155;
    }
    .card {
      background-color: var(--card-bg);
      border: 1px solid #334155;
      color: #f8fafc;
    }
    .btn-primary {
      background-color: var(--accent);
      border: none;
      color: #0f172a !important; /* Better contrast on bright accent */
      font-weight: 600;
    }
    .btn-primary:hover {
      background-color: #0ea5e9;
      color: #fff !important;
    }
    .text-muted {
      color: var(--text-muted) !important;
    }
    #logs-container {
      background: #000;
      color: #00ff00;
      font-family: 'Courier New', Courier, monospace;
      height: 500px;
      overflow-y: scroll;
      padding: 10px;
      border-radius: 5px;
      font-size: 0.9rem;
    }
    .sidebar {
      height: calc(100vh - 56px);
      background-color: var(--card-bg);
      border-right: 1px solid #334155;
    }
    .nav-link {
      color: var(--text-muted);
    }
    .nav-link.active {
      color: var(--accent);
    }
    .nav-link:hover {
      color: #fff;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="bi bi-box-seam me-2"></i>Docker Monitor
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <% if (user) { %>
            <li class="nav-item">
              <span class="nav-link text-white">Welcome, <%= user.name %> (<%= user.role %>)</span>
            </li>
            <% if (user.role === 'admin') { %>
              <li class="nav-item">
                <a class="nav-link" href="/admin"><i class="bi bi-shield-lock me-1"></i>Admin</a>
              </li>
            <% } %>
            <li class="nav-item">
              <a class="nav-link" href="/auth/logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row">
      <main class="col-md-11 mx-auto py-4">
        <%- body %>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
