<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DockPulse</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <style>
    :root {
      --bg-dark: #0f172a;
      --card-bg: #1e293b;
      --accent: #38bdf8;
      --text-muted: #cbd5e1;
    }

    body {
      background-color: var(--bg-dark);
      color: #f8fafc;
      font-family: 'Inter', sans-serif;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    .navbar {
      background-color: rgba(15, 23, 42, 0.8) !important;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: 0.8rem 1.5rem;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .navbar-brand {
      font-weight: 800;
      letter-spacing: -0.5px;
      font-size: 1.4rem;
      background: linear-gradient(135deg, #38bdf8, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .navbar-brand i {
      -webkit-text-fill-color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      background: rgba(56, 189, 248, 0.15);
      border-radius: 10px;
      border: 1px solid rgba(56, 189, 248, 0.3);
      box-shadow: 0 0 20px rgba(56, 189, 248, 0.2);
      font-size: 1.2rem;
    }

    .card {
      background-color: var(--card-bg);
      border: 1px solid #334155;
      color: #f8fafc;
    }

    .btn-primary {
      background-color: var(--accent);
      border: none;
      color: #0f172a !important;
      font-weight: 600;
    }

    .text-muted {
      color: var(--text-muted) !important;
    }

    #logs-container {
      background: #000;
      color: #00ff00;
      font-family: 'Courier New', Courier, monospace;
      height: 500px;
      overflow-y: scroll;
      padding: 10px;
      border-radius: 5px;
      font-size: 0.9rem;
    }

    .nav-link {
      color: var(--text-muted);
      transition: all 0.2s;
    }

    .nav-link:hover {
      color: #fff;
    }

    .nav-link.active {
      color: var(--accent);
    }
  </style>
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="bi bi-box-seam"></i>
        <span>DockPulse</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <% if (user) { %>
            <li class="nav-item me-3">
              <a href="/" class="nav-link <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>">
                <i class="bi bi-grid-3x3-gap me-1"></i> Dashboard
              </a>
            </li>
            <% if (user.role === 'admin') { %>
              <li class="nav-item me-3">
                <a href="/admin" class="nav-link <%= typeof page !== 'undefined' && page === 'admin' ? 'active' : '' %>">
                  <i class="bi bi-gear me-1"></i> Manage
                </a>
              </li>
            <% } %>
            <li class="nav-item me-3">
              <span class="nav-link text-white small">Welcome, <b><%= user.name %></b></span>
            </li>
            <li class="nav-item">
              <a href="/auth/logout" class="nav-link text-danger">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row">
      <main class="col-md-11 mx-auto py-4">
        <%- body %>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>